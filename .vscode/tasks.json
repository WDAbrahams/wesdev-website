{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "WesDev: Dev server",
      "detail": "Start Next.js (npm run dev) at http://localhost:3000 with hot reload",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "owner": "next",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*(Starting|Compiling).*",
          "endsPattern": ".*(Ready in|Compiled|Local:).*"
        }
      },
      "runOptions": {
        "instanceLimit": 1
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "WesDev: Production build",
      "detail": "next build (+ sitemap)",
      "type": "shell",
      "command": "npm run build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    }
  ]
}
