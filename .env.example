# Web3Forms — delivers contact-form submissions to your inbox.
# Get a free access key at https://web3forms.com (it is tied to your email).
# Posted from the browser (the free plan blocks server-side calls), so this must
# be NEXT_PUBLIC_. Optional: the project key is used as a fallback if unset.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Site URL — used for canonical URLs, OG tags, and sitemap generation
NEXT_PUBLIC_SITE_URL=https://wesdev.co.za

# Google Analytics 4 measurement ID — exposed to the browser for gtag.js
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
